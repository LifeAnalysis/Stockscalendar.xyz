{
  "name": "nuvolari-hermes-agent",
  "version": "2.0.0",
  "private": true,
  "description": "Next.js Hermes command center for Nuvolari, Robinhood Chain stocks, and Kalshi intelligence.",
  "scripts": {
    "dev": "node scripts/check-local-env.mjs && rm -rf .next && next build && next start",
    "dev:watch": "node scripts/check-local-env.mjs && rm -rf .next && next dev",
    "dev:loose": "next dev",
    "env:check": "node scripts/check-local-env.mjs",
    "build": "next build",
    "start": "next start",
    "check": "next lint && next build"
  },
  "dependencies": {
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "next": "^15.3.3",
    "postprocessing": "^6.39.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "eslint": "^9.27.0",
    "eslint-config-next": "^15.3.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT"
}
